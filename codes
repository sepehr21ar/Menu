  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--white);
}

.share-link span,
.qr-box span {
  font-weight: 800;
  color: var(--ink);
}

.share-link .public-link {
  display: block;
  padding: 10px 12px;
  border: 1px dashed #b8c8bd;
  border-radius: 7px;
  background: var(--mint);
  color: var(--leaf-dark);
  line-height: 1.35;
