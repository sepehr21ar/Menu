from uuid import uuid4

from fastapi import HTTPException, UploadFile

from app.config import ALLOWED_IMAGE_EXTENSIONS, MAX_IMAGE_SIZE, UPLOAD_DIR


async def save_image(image: UploadFile | None) -> str | None:
    if not image or not image.filename:
        return None

    if image.content_type and not image.content_type.startswith("image/"):
        raise HTTPException(status_code=400, detail="فایل آپلود شده باید تصویر باشد.")

    suffix = Path(image.filename).suffix.lower()
    if suffix not in ALLOWED_IMAGE_EXTENSIONS:
        suffix = ".jpg"

    contents = await image.read()
    if len(contents) > MAX_IMAGE_SIZE:
        raise HTTPException(status_code=400, detail="حجم تصویر نباید بیشتر از ۴ مگابایت باشد.")

    filename = f"{uuid4().hex}{suffix}"
    path = UPLOAD_DIR / filename
    path.write_bytes(contents)

    return f"/static/uploads/{filename}"

