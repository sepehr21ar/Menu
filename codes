          <input type="text" id="restaurant_name" required>
        </label>
        <label>ایمیل
          <input type="email" id="email" required>
        </label>
        <label>رمز عبور
          <input type="password" id="password" required minlength="6">
        </label>
        <button class="button" type="submit">ثبت‌نام</button>
